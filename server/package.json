{
  "name": "@bored-games/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun --watch run src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
